{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/requirement-system/input-schema.json",
  "title": "Requirement System Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "business_context",
    "problem_statement",
    "business_goal"
  ],
  "properties": {
    "project_name": { "type": "string" },
    "business_context": { "type": "string" },
    "problem_statement": { "type": "string" },
    "business_goal": { "type": "string" },
    "success_metrics": { "type": "array", "items": { "type": "string" } },
    "users": { "type": "array", "items": { "$ref": "#/$defs/persona" } },
    "stakeholders": { "type": "array", "items": { "$ref": "#/$defs/stakeholder" } },
    "current_process": { "type": "array", "items": { "type": "string" } },
    "pain_points": { "type": "array", "items": { "type": "string" } },
    "must_have_features": { "type": "array", "items": { "type": "string" } },
    "nice_to_have_features": { "type": "array", "items": { "type": "string" } },
    "reports": { "type": "array", "items": { "type": "string" } },
    "integrations": { "type": "array", "items": { "$ref": "#/$defs/integration" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "non_functional_expectations": { "$ref": "#/$defs/nonFunctionalExpectations" },
    "delivery_preference": { "$ref": "#/$defs/deliveryPreference" },
    "unknowns": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {
        "role": { "type": "string" },
        "description": { "type": "string" },
        "goals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "stakeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "influence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system_name"],
      "properties": {
        "system_name": { "type": "string" },
        "purpose": { "type": "string" },
        "direction": { "type": "string", "enum": ["inbound", "outbound", "bidirectional", "unknown"] }
      }
    },
    "nonFunctionalExpectations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected_user_volume": { "type": "string" },
        "performance": { "type": "string" },
        "availability": { "type": "string" },
        "auditability": { "type": "string" },
        "access_control": { "type": "string" },
        "localization": { "type": "string" }
      }
    },
    "deliveryPreference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "delivery_mode": { "type": "string", "enum": ["mvp_first", "full_scope_first", "unspecified"] },
        "need_brd": { "type": "boolean" },
        "need_srs": { "type": "boolean" },
        "need_architecture_proposal": { "type": "boolean" },
        "need_estimate_and_roadmap": { "type": "boolean" }
      }
    }
  }
}
